# WeHA environment variables
#
# Copy the relevant values into the Cloudflare Pages dashboard
# (Settings, Environment variables). Do NOT create a real .env file in the repo,
# and never commit secrets. This file is a reference only.
#
# Note: this file is named "env.example" (no leading dot) on purpose, because
# .gitignore excludes .env.* patterns. Rename to .env locally only if you need
# local overrides, and never commit that.

# ----- Backend (Cloudflare Pages env vars / secrets) -----

# Resend API key for lead-notification email. SECRET. From the Resend dashboard.
RESEND_API_KEY=re_your_key_here

# Inbox that receives lead notifications.
LEAD_TO_EMAIL=hi@wehelpautomate.com

# Verified Resend sender address.
LEAD_FROM_EMAIL=noreply@wehelpautomate.com

# Optional: Google Sheets / Zapier webhook to mirror leads. No-op if unset.
# SHEETS_WEBHOOK_URL=https://hooks.zapier.com/...

# ----- Frontend (build-time, safe to expose, NEVER put secrets here) -----

# Canonical site URL used for SEO tags. Falls back to the production URL if unset.
REACT_APP_SITE_URL=https://www.wehelpautomate.com
